{
	"name": "eslint-plugin-find-primordials",
	"version": "0.0.0",
	"description": "ESLint plugin to find primordials in use in JavaScript/TypeScript code",
	"keywords": [
		"eslint",
		"plugin",
		"primordials",
		"intrinsics"
	],
	"main": "index.mjs",
	"exports": {
		".": "./index.mjs",
		"./package.json": "./package.json"
	},
	"imports": {
		"#/*": "./*.mjs"
	},
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"attw": "attw -P --profile esm-only",
		"prepack": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\" && npmignore --auto --commentLines=autogenerated",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"prepublishOnly": "safe-publish-latest",
		"update:eslint-docs": "eslint-doc-generator",
		"version": "node ../../release.mjs",
		"dependencies": "node -p \"process.env.npm_command\" | npx \"dt-clean@^1.2.2\" --auto",
		"tests-only": "cd ../.. && npm run tests-only"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ljharb/find-primordials.git",
		"directory": "packages/eslint-plugin"
	},
	"author": "Jordan Harband <ljharb@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/ljharb/find-primordials/issues"
	},
	"homepage": "https://github.com/ljharb/find-primordials/tree/main/packages/eslint-plugin#readme",
	"funding": {
		"url": "https://github.com/sponsors/ljharb"
	},
	"dependencies": {
		"find-primordials": "^0.0.0"
	},
	"devDependencies": {
		"@eslint/core": "^1.2.1",
		"auto-changelog": "^2.6.0",
		"eslint": "^9.39.5 || ^10.7.0",
		"eslint-doc-generator": "^3.7.0",
		"in-publish": "^2.0.1",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"eslint": "^9.39.5 || ^10.7.0"
	},
	"engines": {
		"node": "^24.18 || >= 26.5"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true,
		"appendGitLog": ".",
		"tagPrefix": "eslint-plugin-find-primordials@"
	},
	"publishConfig": {
		"ignore": [
			".editorconfig",
			".github/",
			"eslint.config.mjs",
			"tsconfig.json"
		]
	}
}
