{
	"name": "find-primordials-cli",
	"version": "0.0.0",
	"description": "CLI to find primordials in use in a JavaScript/TypeScript project",
	"keywords": [
		"primordials",
		"cli",
		"javascript",
		"typescript",
		"lint"
	],
	"bin": {
		"find-primordials": "bin.mjs"
	},
	"imports": {
		"#/*": "./*.mjs"
	},
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"attw": "attw -P --profile esm-only",
		"prepack": "node -e \"require('fs').copyFileSync('../../LICENSE', 'LICENSE')\" && npmignore --auto --commentLines=autogenerated",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"prepublishOnly": "safe-publish-latest",
		"version": "node ../../release.mjs",
		"dependencies": "node -p \"process.env.npm_command\" | npx \"dt-clean@^1.2.2\" --auto",
		"tests-only": "cd ../.. && npm run tests-only"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ljharb/find-primordials.git",
		"directory": "packages/cli"
	},
	"author": "Jordan Harband <ljharb@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/ljharb/find-primordials/issues"
	},
	"homepage": "https://github.com/ljharb/find-primordials/tree/main/packages/cli#readme",
	"funding": {
		"url": "https://github.com/sponsors/ljharb"
	},
	"dependencies": {
		"find-primordials": "^0.0.0",
		"ignore": "^7.0.6",
		"pargs": "^1.4.2"
	},
	"devDependencies": {
		"auto-changelog": "^2.6.0",
		"in-publish": "^2.0.1",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": "^24.18 || >= 26.5"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true,
		"appendGitLog": ".",
		"tagPrefix": "find-primordials-cli@"
	},
	"publishConfig": {
		"ignore": [
			".editorconfig",
			".github/",
			"eslint.config.mjs",
			"tsconfig.json"
		]
	}
}
