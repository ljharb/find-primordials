{
	"name": "find-primordials-monorepo",
	"private": true,
	"description": "Find primordials in use in the current project, so you can make your package more robust.",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "eslint .",
		"postlint": "tsc && npm run --if-present --workspaces attw",
		"pretest": "npm run lint",
		"tests-only": "c8 tape 'packages/tests/*.test.mjs'",
		"test": "npm run tests-only",
		"posttest": "npx npm@\">= 10.2\" audit --production",
		"preversion": "echo \"use \\`npm run --no-workspaces version\\` in a subpackage directly\" && exit 1",
		"dependencies": "node -p \"process.env.npm_command\" | npx \"dt-clean@^1.2.2\" --auto"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ljharb/find-primordials.git"
	},
	"author": "Jordan Harband <ljharb@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/ljharb/find-primordials/issues"
	},
	"homepage": "https://github.com/ljharb/find-primordials#readme",
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.5",
		"@ljharb/eslint-config": "^22.2.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/node": "^24.13.3",
		"c8": "^12.0.0",
		"eslint": "^9.39.5 || ^10.7.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": "^24.18 || >= 26.5"
	}
}
